# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# --- LLM ---
# Proveedor: mock | openai | groq
LLM_PROVIDER=groq

# Groq Cloud:
#   llama-3.3-70b-versatile  → mejor calidad (TPM 12k en tier free)
#   llama-3.1-8b-instant     → más rápido, más tokens/min permitidos
#   gpt-oss-20b              → modelo medio rápido
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# Si usas OpenAI en lugar de Groq:
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Modelo del juez de evaluacion. Recomendado uno MAS FUERTE que el respondedor
# para reducir sesgo de autoevaluacion. Si se omite, usa LLM_MODEL.
JUDGE_LLM_MODEL=llama-3.3-70b-versatile

LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1500

# Pausa entre llamadas al LLM (segundos). Útil para tier gratuito.
# 0 = sin pausa. Sube a 1.5-3 si te salen errores 429 frecuentes.
LLM_CHUNK_DELAY_SECONDS=0

# --- Pipeline ---
DOMAIN=offers
# Para reducir el número total de chunks (y de llamadas al LLM), sube CHUNK_SIZE.
# 1200 = chunks pequeños, mejor recall pero más llamadas.
# 3000 = chunks medianos, menos llamadas.
CHUNK_SIZE=2400
CHUNK_OVERLAP=300
MIN_CONFIDENCE=0.5
